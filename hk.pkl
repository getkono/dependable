amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"

// Workspace-wide Rust steps. Each defines a read-only `check` and (where it makes
// sense) a `fix`. Check-only hooks (pre-push) run `check`; fix hooks (pre-commit)
// run `fix`. We define explicit stable, workspace commands rather than the cargo_*
// builtins so clippy gets `-D warnings` and nothing requires a nightly toolchain.

local fmt = new Step {
    glob = "**/*.rs"
    check = "cargo fmt --all --check"
    fix = "cargo fmt --all"
}

local clippy = new Step {
    glob = List("**/*.rs", "**/Cargo.toml")
    check = "cargo clippy --workspace --all-targets -- -D warnings"
    fix = "cargo clippy --fix --allow-dirty --allow-staged --workspace --all-targets"
}

// No `glob`: these always run as a final gate, even when only Cargo.toml changes.
local test = new Step {
    check = "cargo test --workspace"
}

local coverage = new Step {
    check = "cargo llvm-cov --workspace"
}

// commit-msg validates the just-written message against Conventional Commits via convco.
// `--from-stdin` checks the single message we feed in; `--strip` drops git's comment lines
// and trailing whitespace (like `git commit --cleanup=strip`). Skip during merges/reverts:
// git runs commit-msg for merge commits too, and their "Merge ..."/"Revert ..." subjects
// aren't conventional. convco's range check (CI) skips these by default, so we mirror that
// here by short-circuiting when MERGE_HEAD/REVERT_HEAD is present.
local conventional = new Step {
    check = "git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1 || git rev-parse -q --verify REVERT_HEAD >/dev/null 2>&1 || convco check --from-stdin --strip < {{commit_msg_file}}"
}

hooks {
    // pre-commit auto-fixes staged work; `stage` defaults to true so fixes are
    // re-staged, and `stash = "git"` isolates fixes to staged content.
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps {
            ["fmt"] = fmt
            ["clippy"] = clippy
        }
    }

    // commit-msg enforces Conventional Commits; merges/reverts pass through (see step).
    ["commit-msg"] {
        steps {
            ["conventional"] = conventional
        }
    }

    // pre-push is the read-only gate before code reaches the remote.
    ["pre-push"] {
        steps {
            ["fmt"] = fmt
            ["clippy"] = clippy
            ["test"] = test
            ["coverage"] = coverage
        }
    }

    // `hk check` / `hk fix` for manual or CI invocation.
    ["check"] {
        steps {
            ["fmt"] = fmt
            ["clippy"] = clippy
            ["test"] = test
        }
    }
    ["fix"] {
        fix = true
        steps {
            ["fmt"] = fmt
            ["clippy"] = clippy
        }
    }
}
